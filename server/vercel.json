{
  "version": 2,
  "name": "betnexa-globalback",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/remind-inactive",
      "schedule": "0 6 * * 1"
    }
  ]
}
